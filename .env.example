# MongoDB connection string.
# Local (default — requires MongoDB installed):
MONGODB_URI=mongodb://localhost:27017/word-garden

# MongoDB Atlas (cloud, free tier available at https://cloud.mongodb.com):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/word-garden

# API server port (optional, defaults to 3001)
PORT=3001
